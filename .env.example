# ─────────────────────────────────────────
# SMARTFINANCE — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# NUNCA commite o arquivo .env no repositório
# ─────────────────────────────────────────

# ── APLICAÇÃO ──────────────────────────────
NODE_ENV=development
PORT=3000

# ── BANCO DE DADOS (PostgreSQL) ────────────
POSTGRES_USER=smartfinance_user
POSTGRES_PASSWORD=TROQUE_PELA_SUA_SENHA_SEGURA
POSTGRES_DB=smartfinance_db

# URL completa usada pelo Prisma ORM
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://smartfinance_user:TROQUE_PELA_SUA_SENHA_SEGURA@localhost:5432/smartfinance_db

# ── REDIS (Cache + Blacklist JWT) ──────────
REDIS_PASSWORD=TROQUE_PELA_SUA_SENHA_REDIS
# URL completa usada pelo ioredis
# Formato local:  redis://:PASSWORD@localhost:6379
# Formato Upstash: rediss://:TOKEN@HOST:PORT
REDIS_URL=redis://:TROQUE_PELA_SUA_SENHA_REDIS@localhost:6379

# ── AUTENTICAÇÃO (JWT) ─────────────────────
# Gere um segredo forte: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=TROQUE_POR_UM_SEGREDO_DE_64_BYTES_HEX
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── SERVIÇO DE IA (FastAPI) ────────────────
# URL do serviço Python em desenvolvimento local
AI_SERVICE_URL=http://localhost:8000
# Em produção (Render), será algo como:
# AI_SERVICE_URL=https://smartfinance-ai.onrender.com

# ── CORS ───────────────────────────────────
# Domínios permitidos para requisições cross-origin (separados por vírgula)
# Desenvolvimento: http://localhost:4200
# Produção: https://SEU_PROJETO.vercel.app
CORS_ORIGINS=http://localhost:4200
