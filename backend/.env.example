# ─────────────────────────────────────────────────────────────────
# SMARTFINANCE — Variáveis de Ambiente
# Copie este arquivo: cp .env.example .env
# Preencha os valores reais no .env (NUNCA commite o .env)
# ─────────────────────────────────────────────────────────────────

# ── APLICAÇÃO ─────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── BANCO DE DADOS (PostgreSQL) ───────────────────────────────────
# Desenvolvimento (Docker local):
#   postgresql://USER:PASSWORD@localhost:5432/DB_NAME
# Produção (Neon.tech — incluir ?sslmode=require):
#   postgresql://USER:PASSWORD@HOST/DB_NAME?sslmode=require
DATABASE_URL=postgresql://smartfinance_user:CHANGE_ME@localhost:5432/smartfinance_db

# ── REDIS (Cache + Blacklist JWT) ─────────────────────────────────
# Desenvolvimento (Docker local):
#   redis://:PASSWORD@localhost:6379
# Produção (Upstash — usar rediss:// com TLS):
#   rediss://:TOKEN@HOST:PORT
REDIS_URL=redis://:CHANGE_ME@localhost:6379

# ── AUTENTICAÇÃO (JWT) ────────────────────────────────────────────
# Gere um segredo forte para produção:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_USE_64_RANDOM_BYTES
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── SERVIÇO DE IA (FastAPI) ───────────────────────────────────────
# Desenvolvimento: http://localhost:8000
# Produção (Render): https://smartfinance-ai.onrender.com
AI_SERVICE_URL=http://localhost:8000

# ── CORS ──────────────────────────────────────────────────────────
# Desenvolvimento: http://localhost:4200
# Produção: https://SEU_PROJETO.vercel.app
CORS_ORIGINS=http://localhost:4200
